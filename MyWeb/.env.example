# MyAgent API endpoint used by browser fetch calls in built/preview deployments.
# Leave EMPTY during local dev so Vite's /api proxy handles requests (avoids CORS).
# Only set this for production builds or when NOT using the Vite dev server.
# VITE_API_BASE_URL=http://localhost:8000

# Optional. Must match MyAgent's MYDEVTEAM_API_KEY when API auth is enabled.
# Leave empty when backend is started without MYDEVTEAM_API_KEY (no auth required).
# The login/register page can also store this at runtime in localStorage.
# VITE_API_KEY=

# Vite dev-server proxy target for /api requests.
VITE_DEV_API_PROXY_TARGET=http://localhost:8000

# DevTeam API (separate from MyAgent API)
VITE_DEVTEAM_API_URL=http://localhost:4223
